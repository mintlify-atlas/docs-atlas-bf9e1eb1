  "keyFeatures": [
    "Space (Espacio) management: create, retrieve, and delete coworking spaces with capacity and cleaning time",
    "Reservation (Reserva) lifecycle: create, read, update status, and delete bookings with conflict-aware scheduling",
    "User (Usuario) management: register, retrieve, and delete users with email uniqueness enforcement",
    "OpenAPI / Swagger UI available at /api-docs via springdoc-openapi",
    "PostgreSQL backend with SSL support (Supabase-compatible)",
    "Optimistic locking on Reserva entities via JPA @Version",
    "CORS configured for the companion Next.js dashboard (swagger-to-ui)",
    "Global exception handling for duplicate-email errors via @RestControllerAdvice"
  ],
  "publicApiSurface": [
    "GET /espacios/all",
    "GET /espacios/{id}",
    "POST /espacios/create",
    "DELETE /espacios/eliminar/{id}",
    "GET /espacios/ping",
    "GET /reserva/all",
    "GET /reserva/{id}",
    "POST /reserva/create",
    "PUT /reserva/update/{id}",
    "DELETE /reserva/eliminar/{id}",
    "GET /reserva/ping",
    "GET /usuarios/all",
    "GET /usuarios/{id}",
    "POST /usuarios/create",
    "DELETE /usuarios/eliminar/{id}",
    "GET /usuarios/ping"
  ]
}
